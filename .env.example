# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/hrms_db?schema=public"

# Cache Configuration (Redis)
REDIS_URL="redis://localhost:6379"

# Security Configurations
JWT_SECRET="generate-a-secure-secret-key-containing-at-least-32-characters"
JWT_REFRESH_SECRET="generate-another-secure-secret-key-containing-at-least-32-characters"
JWT_EXPIRES_IN="1d"
SESSION_TTL=86400

# SMTP Configuration (Optional - Defaults to console log stub if empty)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL="no-reply@hrms.example.com"
SMTP_FROM_NAME="HRMS Support"

