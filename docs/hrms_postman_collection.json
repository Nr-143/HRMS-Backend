				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.data && response.data.token) {",
									"    pm.collectionVariables.set(\"token\", response.data.token);",
									"    console.log(\"Saved JWT Token to variables.\");",
									"}",
									"if (response.data && response.data.user && response.data.user.tenantId) {",
									"    pm.collectionVariables.set(\"tenant_id\", response.data.user.tenantId);",
									"    console.log(\"Saved Tenant ID to variables.\");",
									"}"
								],
								"type": "javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@acme.example.com\",\n    \"password\": \"AcmeAdminPassword123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						},
						"description": "Authenticate user credentials, issue a JWT session token, and automatically save the token and tenant ID to Postman variables."
					},
					"response": []
				},
